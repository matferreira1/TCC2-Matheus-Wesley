# ─────────────────────────────────────────────────────────
# .env.example — copie para .env e ajuste os valores locais
# ─────────────────────────────────────────────────────────

# Geral
APP_NAME=IAJuris
DEBUG=false

# Banco de dados SQLite
DATABASE_URL=data/db/iajuris.db

# Provedor LLM ativo: "groq" ou "ollama"
LLM_PROVIDER=groq

# Groq (API externa — obtenha sua chave em https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=60

# Ollama (LLM local — usado quando LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=600

# RAG
RAG_TOP_K=5
RAG_MAX_TOKENS=2048
RAG_MAX_EMENTA_CHARS=1500
